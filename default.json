{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "automerge": true,
    "automergeStrategy": "squash",
    "automergeType": "branch",
    "commitMessageAction": "Upgrade",
    "customManagers": [
        {
            "description": "update versions in GitHub Actions workflows",
            "customType": "regex",
            "managerFilePatterns": ["/^\\.github/workflows/[^/]+\\.ya?ml$/"],
            "matchStrings": [
                ": +(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>[^\\s]+))? +# +renovate: +datasource=(?<datasource>[^\\s]+) +depName=(?<depName>[^\\s]+)(?: +(?:packageName|lookupName)=(?<packageName>[^\\s]+))?(?: +versioning=(?<versioning>[^\\s]+))?"
            ]
        }
    ],
    "gitAuthor": "Renovate <renovate@example.com>",
    "git-submodules": {
        "enabled": true
    },
    "minimumReleaseAge": "7 days",
    "minimumReleaseAgeBehaviour": "timestamp-optional",
    "packageRules": [
        {
            "description": "use dependency name without suffixes for commit messages",
            "commitMessageTopic": "{{depName}}",
            "matchPackageNames": ["*"]
        },
        {
            "groupName": "CDN",
            "matchDatasources": ["cdnjs"]
        },
        {
            "groupName": "Docker",
            "matchDatasources": ["docker"]
        },
        {
            "groupName": "GitHub Actions",
            "matchDepTypes": ["action"]
        },
        {
            "groupName": "npm",
            "matchDatasources": ["npm"]
        },
        {
            "groupName": "PyPI",
            "matchDatasources": ["pypi"]
        },
        {
            "groupName": "Python",
            "matchPackageNames": ["python"]
        },
        {
            "description": "slow down Renovate releases",
            "matchDepNames": ["ghcr.io/renovatebot/renovate"],
            "schedule": ["* 0-3 * * 6"]
        }
    ],
    "pinDigests": true,
    "vulnerabilityAlerts": {
        "enabled": false
    }
}
