{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "automerge": true,
    "automergeStrategy": "squash",
    "automergeType": "branch",
    "commitMessageAction": "Upgrade",
    "customManagers": [
        {
            "customType": "regex",
            "description": "Update versions in GitHub Actions workflows",
            "managerFilePatterns": ["/^\\.github/workflows/[^/]+\\.ya?ml$/"],
            "matchStrings": [
                ": (?<currentValue>.+?)(?:@(?<currentDigest>.+?))? # renovate: datasource=(?<datasource>.+?) depName=(?<depName>.+?)(?: (?:packageName|lookupName)=(?<packageName>.+?))?(?: versioning=(?<versioning>.+?))?\\s"
            ]
        }
    ],
    "gitAuthor": "Renovate <renovate@example.com>",
    "git-submodules": {
        "enabled": true
    },
    "minimumReleaseAge": "7 days",
    "packageRules": [
        {
            "commitMessageTopic": "{{depName}}",
            "matchPackageNames": ["*"]
        },
        {
            "groupName": "CDN",
            "matchDatasources": ["cdnjs"]
        },
        {
            "groupName": "Docker",
            "matchDatasources": ["docker"]
        },
        {
            "groupName": "GitHub Actions",
            "matchDepTypes": ["action"]
        },
        {
            "groupName": "npm",
            "matchDatasources": ["npm"]
        },
        {
            "groupName": "PyPI",
            "matchDatasources": ["pypi"]
        },
        {
            "groupName": "Python",
            "matchPackageNames": ["python"]
        }
    ],
    "pinDigests": true,
    "vulnerabilityAlerts": {
        "enabled": false
    }
}
